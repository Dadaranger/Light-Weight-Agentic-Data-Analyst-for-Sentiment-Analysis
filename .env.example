# Ollama
OLLAMA_HOST=http://localhost:11434
ADA_PLANNER_MODEL=qwen2.5:7b-instruct
ADA_ROUTER_MODEL=qwen2.5:3b-instruct
ADA_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Paths
ADA_PROJECTS_DIR=./projects
ADA_DEFAULT_PROJECT=_example

# Behavior
ADA_AUTO_APPROVE_LOW_RISK=false
ADA_MAX_QUESTIONS_PER_RUN=0     # 0 = unlimited
ADA_LOG_LEVEL=INFO
